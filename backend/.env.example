PORT=5000
FRONTEND_ORIGIN=http://localhost:5173

# Option A: Gmail (uses smtp.gmail.com:465 on the server)
EMAIL_SERVICE=gmail
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_gmail_app_password
RECEIVER_EMAIL=receiver@example.com
# EMAIL_SEND_TIMEOUT_MS=25000

# Option B: Resend (recommended on Render — uses HTTPS API, not SMTP)
# RESEND_API_KEY=re_your_api_key
# EMAIL_USER=onboarding@resend.dev
# RECEIVER_EMAIL=you@example.com
# SMTP_HOST=smtp.resend.com  # optional; triggers Resend API when API key is set

# Option C: Host-based SMTP (Gmail/other providers)
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=

PORT=5000
FRONTEND_ORIGIN=http://localhost:5173

# Option A: Gmail (uses smtp.gmail.com:465 on the server)
EMAIL_SERVICE=gmail
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_gmail_app_password
RECEIVER_EMAIL=receiver@example.com
# EMAIL_SEND_TIMEOUT_MS=25000

# Option B: Host-based SMTP (recommended for Resend/SES/SendGrid SMTP relay)
SMTP_HOST=
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=
SMTP_PASS=
